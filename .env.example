# AvodaNow local environment template
# Copy to `.env` and fill in the real values.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Required for app runtime and Drizzle commands.
# Prefer POSTGRES_URL for PostgreSQL; DATABASE_URL is kept for compatibility.
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/avodanow
DATABASE_URL=

# Required for isolated integration tests only.
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/jobnow_test

# -----------------------------------------------------------------------------
# Auth / Manus-style OAuth
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-secret
VITE_ENABLE_OAUTH_LOGIN=false
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# -----------------------------------------------------------------------------
# Forge / built-in platform services
# Used by storage, maps proxy, notifications, email helper, image generation,
# voice transcription, and other Manus-derived helpers.
# -----------------------------------------------------------------------------
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# -----------------------------------------------------------------------------
# Matching service
# Optional unless you use worker matching / job-offer integration.
# -----------------------------------------------------------------------------
MATCHING_API_URL=

# -----------------------------------------------------------------------------
# SMS / Twilio
# TWILIO_VERIFY_SERVICE_SID is used for OTP flows.
# TWILIO_FROM_NUMBER is used for plain outbound SMS messages.
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Email
# SENDGRID_* is used by email OTP and welcome emails.
# SMTP_* is used by other transactional email helpers.
# APP_BASE_URL is used for unsubscribe links, SMS links, sitemap/robots URLs,
# and other server-generated links.
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@avodanow.co.il
APP_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Web Push
# Optional unless push notifications are enabled.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Frontend analytics
# Optional unless cookie-consent analytics integration is enabled.
# -----------------------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
