# ─────────────────────────────────────────────────────────────────────────────
# .env.test — Isolated TEST environment
#
# ⚠️  NEVER use production credentials here.
# ⚠️  This file is committed to git — do NOT put real secrets here.
# ⚠️  All external services (SendGrid, Twilio, etc.) are MOCKED in tests.
#
# To run integration tests:
#   pnpm test:integration
#
# To reset the test DB:
#   pnpm db:seed:test
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=test

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL — completely isolated from production Neon DB
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/jobnow_test

# ── Auth ──────────────────────────────────────────────────────────────────────
# Deterministic test secret — not used in production
JWT_SECRET=test-jwt-secret-do-not-use-in-production-32chars
VITE_ENABLE_GOOGLE_LOGIN=true

# ── External services (all mocked in tests) ───────────────────────────────────
# These values are intentionally fake — all external calls are vi.mock()'d
SENDGRID_API_KEY=SG.test-fake-key-not-real
EMAIL_FROM=test@test.invalid
TWILIO_ACCOUNT_SID=ACtest00000000000000000000000000000
TWILIO_AUTH_TOKEN=test-auth-token-fake
TWILIO_VERIFY_SERVICE_SID=VAtest0000000000000000000000000000

# ── OAuth (mocked in tests) ───────────────────────────────────────────────────
 
VITE_ENABLE_GOOGLE_LOGIN=true
GOOGLE_CLIENT_ID=test-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=test-google-client-secret
OWNER_NAME=Test Owner

# ── Forge API (mocked in tests) ───────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=http://localhost:9999/mock-forge
BUILT_IN_FORGE_API_KEY=test-forge-key-fake
VITE_FRONTEND_FORGE_API_KEY=test-frontend-forge-key-fake
VITE_FRONTEND_FORGE_API_URL=http://localhost:9999/mock-forge
